# ============================================================================
# RCM AI Platform — environment configuration
# Copy this file to .env and fill in real values before running docker-compose
# or the backend/frontend directly. Never commit a real .env file.
# ============================================================================

# --- App -------------------------------------------------------------------
APP_NAME="RCM AI Platform"
APP_ENV=development                 # development | staging | production
DEBUG=false
FRONTEND_URL=http://localhost:3000

# --- Security ----------------------------------------------------------------
# JWT_SECRET_KEY: random 64+ char secret used to sign access/refresh tokens.
#   Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
# ENCRYPTION_KEY: Fernet key used to encrypt provider API keys at rest.
#   Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=30

# --- Database (docker-compose overrides DATABASE_URL to point at the
#     "postgres" service automatically — these are only used outside Docker,
#     or to set the Postgres container's own root credentials) ---------------
POSTGRES_USER=rcm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rcm_ai_platform
DATABASE_URL=postgresql+asyncpg://rcm:change-me@localhost:5432/rcm_ai_platform
DATABASE_URL_SYNC=postgresql+psycopg2://rcm:change-me@localhost:5432/rcm_ai_platform

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object storage (S3-compatible; docker-compose ships MinIO for local dev)
S3_ENDPOINT_URL=http://localhost:9000     # unset/remove to use real AWS S3
S3_ACCESS_KEY_ID=rcm-minio-admin
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET_NAME=rcm-ai-platform
S3_REGION=us-east-1
S3_USE_SSL=false

# --- AI providers --------------------------------------------------------
# Only the providers you configure a key for will be usable; the platform
# runs fine with just one configured (e.g. Anthropic only).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEFAULT_AI_PROVIDER=auto                  # anthropic | openai | gemini | auto
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-5
OPENAI_DEFAULT_MODEL=gpt-4.1
GEMINI_DEFAULT_MODEL=gemini-2.0-pro
AI_PROVIDER_DATA_RETENTION_DAYS=0

# --- SSO ---------------------------------------------------------------------
# Google Workspace OAuth 2.0 client (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft Entra ID (Azure AD) app registration (portal.azure.com)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# --- RAG / Knowledge Base ---------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=6

# --- Compliance --------------------------------------------------------------
PHI_BLOCK_ON_DETECTION_DEFAULT=true
CONVERSATION_RETENTION_DAYS_DEFAULT=365
AUDIT_LOG_RETENTION_DAYS=730

# --- Rate limiting -------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# --- CORS (comma-separated list consumed by the backend as JSON/py-list via
#     pydantic-settings; for a single origin just set the one URL) ---------
CORS_ORIGINS=["http://localhost:3000"]

# --- Seed data (first admin user created by `python -m app.db.seed`) -----
SEED_ADMIN_EMAIL=admin@techmatter.co
SEED_ADMIN_PASSWORD=change-me-immediately

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
